# In dev, talk to Vite (same-origin) and let it proxy to your local Dev-co API.
# Start the backend once: cd Dev-co && npm run dev
# Login dropdown sends X-Dispatch-Environment (test | prod) — no need to restart the server.
VITE_API_BASE_URL=/api/v1
VITE_API_PROXY_TARGET=http://localhost:4000
# Get a key from Google Cloud → enable Maps JavaScript API + Geocoding API + billing
# VITE_GOOGLE_MAPS_API_KEY=
