# Production / preview builds — full API URL (CORS must allow your web origin).
VITE_API_BASE_URL=https://dev-co-production.up.railway.app/api/v1

# Login dropdown uses header X-Dispatch-Environment: test | prod on the same API host.
# Backend must have MONGODB_URI_TEST and MONGODB_URI_PROD configured (see Dev-co/.env.example).

# Local dev only — where Vite proxies /api and /uploads (see vite.config.js).
# VITE_API_PROXY_TARGET=http://localhost:4000

# Google Maps — Maps JavaScript API + Geocoding API (billing required on GCP project).
# VITE_GOOGLE_MAPS_API_KEY=

# Firebase Cloud Messaging (web push) — from Firebase Console → Project settings → Web app
# Also generate Web Push VAPID key: Build → Cloud Messaging → Web Push certificates
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=rapidroute-a5439.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=rapidroute-a5439
# VITE_FIREBASE_STORAGE_BUCKET=rapidroute-a5439.firebasestorage.app
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_VAPID_KEY=
//